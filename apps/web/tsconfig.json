{
  "extends": "@chat-buddy/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@store": ["./store/index.ts"],
      "@store/*": ["./store/*"],
      "@lib/*": ["./lib/*"],
      "@services": ["./services/index.ts"],
      "@services/*": ["./services/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
