{
  "name": "@chat-buddy/database",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "db:test": "tsx ./src/scripts/test-db-connection.ts",
    "db:migrate": "tsx ./src/scripts/migrate.ts",
    "db:rollback": "tsx ./src/scripts/rollback.ts",
    "db:seed": "tsx ./src/scripts/seed.ts",
    "db:create-migration": "tsx ./src/scripts/create-migration.ts"
  },
  "dependencies": {
    "@chat-buddy/shared": "*",
    "dotenv": "^17.2.3",
    "knex": "^3.1.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
